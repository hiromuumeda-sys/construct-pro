# Supabase の接続文字列（Connection Pooler / Transaction mode・ポート6543 推奨）
# Supabase ダッシュボード > Project Settings > Database > Connection string > "Transaction" からコピー
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ローカル起動ポート（任意）
PORT=4500

# メール送信（任意・請求書/発注書のメール送信を使う場合のみ）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CONSTRUCT_PRO <noreply@construct-pro.jp>
