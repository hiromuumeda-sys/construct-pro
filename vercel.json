{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["fonts/**"] }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/public/login.html" },
    { "src": "/(.+\\.(?:js|css|png|jpe?g|svg|webp|ico|woff2?|ttc))", "headers": { "cache-control": "public, max-age=31536000, immutable" }, "dest": "/public/$1" },
    { "src": "/(.+)", "dest": "/public/$1" }
  ]
}
